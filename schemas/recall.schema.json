{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenPharmaDB Recall Schema",
  "description": "Canonical recall schema for OpenPharmaDB",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "regulator",
    "country",
    "title",
    "product",
    "category",
    "classification",
    "reason",
    "recall_date",
    "url",
    "extras"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "regulator": {
      "type": "string",
      "minLength": 1
    },
    "country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "title": {
      "type": ["string", "null"]
    },
    "product": {
      "type": ["string", "null"]
    },
    "category": {
      "type": ["string", "null"]
    },
    "classification": {
      "type": ["string", "null"]
    },
    "reason": {
      "type": ["string", "null"]
    },
    "recall_date": {
      "type": ["string", "null"]
    },
    "url": {
      "type": ["string", "null"]
    },
    "extras": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}